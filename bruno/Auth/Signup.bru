meta {
  name: Signup
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/signup
  body: json
  auth: none
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}",
    "name": "{{user_name}}"
  }
}

script:post-response {
  const body = res.getBody();
  if (res.getStatus() === 201 && body.id) {
    bru.setEnvVar("user_id", String(body.id));
  }
}
