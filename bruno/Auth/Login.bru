meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

script:post-response {
  const body = res.getBody();
  if (res.getStatus() === 200 && body.access_token) {
    bru.setEnvVar("access_token", body.access_token);
  }
}
