meta {
  name: Create Category
  type: http
  seq: 2
}

post {
  url: {{base_url}}/categories/?user_id={{user_id}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "Groceries",
    "category_type": "expense"
  }
}

script:post-response {
  const body = res.getBody();
  if (res.getStatus() === 201 && body.id) {
    bru.setEnvVar("category_id", String(body.id));
  }
}
